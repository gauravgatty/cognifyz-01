<!DOCTYPE html>
<html>
<head>
    <title>Result</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #43cea2, #185a9d);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            width: 350px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            text-align: center;
        }

        h2 {
            color: #333;
            margin-bottom: 20px;
        }

        p {
            font-size: 16px;
            margin: 10px 0;
        }

        .highlight {
            color: #667eea;
            font-weight: bold;
        }

        a {
            display: inline-block;
            margin-top: 20px;
            text-decoration: none;
            background: #667eea;
            color: white;
            padding: 10px 15px;
            border-radius: 8px;
            transition: 0.3s;
        }

        a:hover {
            background: #5a67d8;
        }
    </style>
</head>
<body>

<div class="card">
    <h2>✅ Submitted Successfully</h2>

    <p>Name: <span class="highlight"><%= name %></span></p>
    <p>Email: <span class="highlight"><%= email %></span></p>

    <a href="/">⬅ Go Back</a>
</div>

</body>
</html>